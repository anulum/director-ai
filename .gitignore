# =====================================================================
# LOCAL-ONLY DIRECTORIES (NEVER pushed to remote)
# =====================================================================

# Private drafts, ideas, and TODO notes
.local/
DEV_LOG.md
claude-director-ai.md
.claude/
.coordination/
.gemini_audit_prompt.md

# Outreach emails, scripts, logs (contains credentials and contact data)
docs/internal/

# Internal audit/review documents (never public-facing)
SECURITY_AUDIT_PREP.md
AUDIT_*.md

# GPU training artifacts (local-only)
*.tar.gz
gpu_results/

# Documentation prose (quarantined until headers/protocols are reviewed)
# Remove this line once docs/ prose files have been audited.
# docs/assets/ is tracked (header image, generator script).
docs/*
!docs/assets/
!docs/conf.py
!docs/index.rst
!docs/api/
!docs/_static/
!docs/LAUNCH_POSTS.md
!docs/ROADMAP_2026_2027.md
!docs/TECHNICAL_SPEC_V2.md
!docs/API_REFERENCE.md
!docs/DATA_PIPELINE.md
!docs/BUILD_JUDGE_DATASET.md
!docs/E2E_EVAL.md
!docs/JUDGE_BENCHMARK.md
!docs/RUST_FFI_PIPELINE.md
!docs/BENCHMARKS.md
!docs/PRODUCTION_CHECKLIST.md
!docs/SIEVING.md
docs/_build/

