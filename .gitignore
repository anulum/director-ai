# every generated result is next to the contract it adheres to.
!benchmarks/results/SCHEMA.md
benchmarks/.cache/
benchmarks/*.jsonl
benchmarks/forge_ab_results.json

# =====================================================================
# HuggingFace Model Cache & Training Artifacts
# =====================================================================
ckpts/
# Ignore everything under /training/ EXCEPT the whitelisted files
# below. Pattern is ``/training/*`` (not ``/training/``) so the
# directory itself is not excluded — required for ``!`` exceptions
# to take effect on child paths.
/training/*
!/training/_upload_all.py
!/training/build_judge_dataset.py
!/training/data_pipeline.py
!/training/distil_factcg.py
!/training/distil_v5_cloud.py
!/training/Dockerfile.distil
!/training/Dockerfile.benchmarks
!/training/launch_cloud.sh
!/training/requirements-distil.in
!/training/requirements-distil.txt
!/training/run_vertex.sh
!/training/train_cloud_large.py
!/training/train_hallucination_detector.py
!/training/train_judge.py
!/training/upcloud_setup.sh
!/training/upload_to_hub.py
data/
/models/
!src/director_ai/models/
features/
*.tmp

# MkDocs build output
site/

# Local backups — never committed
BACKUP/
ARCHIVE/
MODELS/

# Lower-case models symlink (machine-specific path on dev rig)
/models
# nohup wrapper output — ephemeral
nohup.out
# Auto-generated benchmark / analysis reports — never committed
/reports/

# Gemini Internal
docs/internal/gemini/

# Multi-agent coordination metadata (local audit snapshot, never committed)
.agent_metadata.json
