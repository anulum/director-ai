# Line ending normalization
* text=auto eol=lf

# Linguist overrides
*.rs linguist-language=Rust
*.wgsl linguist-language=WGSL

# Binary files (no diff, no merge)
*.npz binary
*.npy binary
*.onnx binary
*.pt binary
*.pkl binary
*.png binary
*.jpg binary
*.svg binary

# Lock files — generated, do not diff
Cargo.lock linguist-generated
