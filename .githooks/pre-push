#!/usr/bin/env bash
# SPDX-License-Identifier: AGPL-3.0-or-later
# Pre-push hook: fast lint gates (ruff, version-sync, bandit).
# Mypy/pytest run in CI — pre-push catches the quick failures.
set -e
echo "Running preflight checks (lint gates)..."
REPO_DIR="$(cd "$(dirname "$0")/.." && pwd)"
if [ -x "$REPO_DIR/.venv/bin/python" ]; then
    PYTHON="$REPO_DIR/.venv/bin/python"
else
    PYTHON="/home/anulum/venv-rocm/bin/python"
fi
"$PYTHON" tools/preflight.py --no-tests
