{
  "annotations": {"list": []},
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Reviews / minute",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "targets": [
        {
          "expr": "rate(director_reviews_total[1m]) * 60",
          "legendFormat": "{{instance}}"
        }
      ]
    },
    {
      "title": "Hallucination rate (1m)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "targets": [
        {
          "expr": "rate(director_hallucinations_total[1m]) / rate(director_reviews_total[1m])",
          "legendFormat": "{{instance}}"
        }
      ]
    },
    {
      "title": "Review latency p50/p95/p99 (ms)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(director_review_duration_seconds_bucket[5m])) * 1000",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, rate(director_review_duration_seconds_bucket[5m])) * 1000",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, rate(director_review_duration_seconds_bucket[5m])) * 1000",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "title": "Coherence score distribution",
      "type": "histogram",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "targets": [
        {
          "expr": "director_coherence_score",
          "legendFormat": "{{instance}}"
        }
      ]
    },
    {
      "title": "Active streaming sessions",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 16},
      "targets": [
        {
          "expr": "director_streaming_active_sessions",
          "legendFormat": "active"
        }
      ]
    },
    {
      "title": "Streaming halts / min",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 16},
      "targets": [
        {
          "expr": "rate(director_streaming_halts_total[1m]) * 60",
          "legendFormat": "halts/min"
        }
      ]
    },
    {
      "title": "KB queries / min",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 16},
      "targets": [
        {
          "expr": "rate(director_knowledge_queries_total[1m]) * 60",
          "legendFormat": "queries/min"
        }
      ]
    },
    {
      "title": "Error rate",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 16},
      "targets": [
        {
          "expr": "rate(director_errors_total[5m]) * 60",
          "legendFormat": "errors/min"
        }
      ]
    },
    {
      "title": "Drift score (7-day window)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 20},
      "targets": [
        {
          "expr": "director_drift_score",
          "legendFormat": "drift"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 0.1},
              {"color": "red", "value": 0.2}
            ]
          }
        }
      }
    }
  ],
  "schemaVersion": 39,
